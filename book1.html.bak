<main>
	 <section id="bookinfo">
	 <div id="leftbox">
	     <a href="shop.html">Back to Shop</a>
	     <h1>The Hunger Games</h1>
		 <p id="author">Suzanne Collins</p>
		 <p id="sinopsis">In a dystopian, post-apocalyptic nation of Panem, 
		 the ruthless Capitol controls twelve districts by forcing
		 them to send one boy and one girl, aged 12-18, to compete in 
		 a televised, mandatory fight-to-the-death called the Hunger Games. 
		 Sixteen-year-old Katniss Everdeen volunteers to replace her younger 
		 sister, Primrose, in the 74th annual games.</p>
		 
		 <div>
	         <p id="price">19.99€</p>
	     </div>
	 
	     <div id="buttons">
	         <button>Add to Cart</button>
	         <button>Favourite</button>
	     </div>
	 </div>
	 
	 <img id="bookcover" src="thgcover.jpg">
	 
	 </section>
	 <section>
