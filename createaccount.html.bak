<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Paperback Parlor</title>
</head>
<style>
     body {
	 background-color: White;
	 margin: 0;
	 padding: 0;
	 }
	 
     #header {
	     background-color: Teal;
		 height: 45px;
		 overflow: hidden;
	     #logo {
		     float: left;
			 width: 90px;
			 height: 35px;
			 margin-top: 5px;
			 margin-bottom: 5px;
			 margin-left: 45px;
		 }
		 
		 #menu {
		 padding-left: 490px;
		 position: absolute;
		 
	     a:hover {
	         color: #b78160;
	     }
	 
	     ul {
	         list-style-type: none;
		     overflow: hidden;
		 }
		 
	     ul li {
		     font-family: "Bebas Neue", sans-serif;
             font-weight: 400;
             font-style: normal;
			 display: inline;
	     }
		 
	     ul li a {
		     text-decoration: none;
		     text-align: center;
		     padding: 14px 16px;
		     color: white;
			 cursor: pointer;
	     }
		 }
 
		 #icons {
		     height: 45px;
		     margin-right: 45px;
		     margin-top: 0;
		     float: right;
			 display: flex;
             justify-content: center;
             align-items: center;

		 ul {
	         list-style-type: none;
		     overflow: hidden;
			 }
			 
		 ul li {
		 display: inline;
		 padding: 15px 15px;
		 }
			 
		 img {
		     width: 22px;
			 height: 22px;
		     }
		 
		 }
	 }
	 
	 #createaccount {
	 background-color: Teal;
	 width: 700px;
	 border-radius: 12px;
	 margin-left: 240px;
	 margin-top: 100px;
	 margin-bottom: 100px;
	 padding-left: 70px;
	 padding-right: 70px;
	 padding-top: 30px;
	 padding-bottom: 10px;
	     h2 {
		     color: #b78160;
			  font-family: "Bebas Neue", sans-serif;
		 }
		 h3 {
		     color: white;
			  font-family: "Bebas Neue", sans-serif;
		 }
		 p {
		     color: white;
			 font-family: "Bebas Neue", sans-serif;
		 }
	 }
	 
     #inputtext {
	      input {
		     width: 700px;
			 padding: 15px;
			 margin-bottom: 15px;
			 border-radius: 12px;
			 background: BurlyWood;
			 border-style: solid;
			 border-color: #b78160;
		  }
		  input:focus {
		  outline-color: white;
		  }
	 }
	 
	 ::placeholder {
         color: #b78160;
	}
	
	 #terms {
	     label {
		 color: white;
		 font-family: "Bebas Neue", sans-serif;
		 font-size: 12px;
		 }
	 }
	 
	 #create {
	     background-color: BurlyWood;
	     color: white;
		 border: none;
		 padding-left: 20px;
		 padding-right: 20px;
		 padding-top: 10px;
		 padding-bottom: 10px;
		 display: inline-block;
		 border-radius: 7px;
		 font-family: "Bebas Neue", sans-serif;
		 cursor: pointer;
		 margin-top: 60px;
		 margin-left: 310px;
	 }
	 
	 #create:hover {
	     background-color: #b78160;
	     color: white;
	 }
		
	 #login {
	     color: white;
		 font-family: "Bebas Neue", sans-serif;
		 font-size: 14px;
		 margin-left: 230px;
	 }
	 
	 .link {
	     color: BurlyWood;
		 font-family: "Bebas Neue", sans-serif;
	 }
	 
	 .link:hover {
	     color: #b78160;
	 }
	
	 
	 #base {
	     background-color: teal;
		 overflow: hidden;
		 height: 270px;
		 }
		 
	     #logobase {
		     float: left;
			 width: 150px;
			 margin-top: 55px;
			 margin-left: 150px;
		     img {
			     width: 200px;
			     height: 90px;
			 }
			 p {
			     color: white;
				 font-family: "Bebas Neue", sans-serif;
				 width: 170px;
				 font-size: 12px;
				 margin-left: 30px;
			 }
		 }
		 
		 #menubase {
			 margin-top: 55px;
			 margin-left: 260px;
			 align-items: center;
			     ul {
			     list-style-type: none;
				 } 
				 ul li {
				 padding: 5px;
				 display: block;
				 font-family: "Bebas Neue", sans-serif;
				 text-align: center;
				 }
				 a {
				 color: white;
				 text-decoration: none;
				 }
				 a:hover {
				 color: BurlyWood;
				 }
		 }
		 
		 #contactus {
		 float: right;
		 margin-right: 170px;
		 margin-top: 45px;
		     ul {
			     list-style-type: none;
			 } 
		     ul li {
				 padding: 5px;
				 font-family: "Bebas Neue", sans-serif;
				 display: block;
				 color: white;
			 }
		 h3 {
		 color: white;
		 font-family: "Bebas Neue", sans-serif;
		 padding-left: 43px;
		 }
		 }
		 
	 .blocks {
	     align-items: center;
	     display: inline-block; 
	 }
	 
	 #copyright {
	     color: white;
		 font-family: "Bebas Neue", sans-serif;
		 font-size: 11px;
		 margin-top: 50px;
		 margin-bottom: 10px;
		 padding-left: 540px;
	 }
	 
	 
</style>


<body>

<header>
<section id="header">
     <img src="logo.png" id="logo">
<nav id="menu">
    <ul>
		<li><a href="home.html">Home</a></li>
		<li><a href="shop.html">Shop</a></li>
		<li><a href="events.html">Events</a></li>
		<li><a href="about.html">About Us</a></li>
	</ul>
</nav>

<div id="icons">
     <ul>
	     <li><a href><img src="profile.png"></a></li>
		 <li><a href><img src="fav.png"></a></li>
		 <li><a href><img src="cart.png"></a></li>
	 </ul>
</div>

</section>
</header>

<main>
     <section id="createaccount">
		     <h2>CREATE ACCOUNT</h2>
			 <h3>Join the PaperBack Parlor Family!</h3>
			 <p>You can browse and shop the best books in town, create a collection of your desired next reads, be up-to-date
			 with the upcoming events, and more!</p>
			 <form>
			 <div id="inputtext">
			 <input type="text" id="fullname" name="fullname" placeholder="full&nbsp;name">
			 <input type="email" id="email" name="email" placeholder="ex.:&nbsp;email@email.com">
			 <input type="password" id="password" name="password" placeholder="password">
			 <input type="password" id="passwordrepeat" name="passwordrepeat" placeholder="repeat&nbsp;password">
			 </div>
			 <div id="terms">
			 <input type="checkbox" id="termscondition" name="choice" value="termscondition">
			 <label>I accept the <a href class="link">terms&amp;conditions</a> and <a href class="link">privacy policy</a> </label>
			 </div>
			 <button id="create" type="submit">CREATE</button>
			 <p id="login"><a href="login.html" class="link" style="text-decoration: none; font-weight: bold;">Log in</a> if you already have an account</p>
			 </form>
	 </section>
</main>

<footer>
<section id="base">
     <div class="blocks" id="logobase">
	     <img src="logo.png" alt="logo">
		 <p>Your next favorite read is one click away</p>
	 </div>
	 
	 <div class="blocks" id="menubase">
	     <ul id="basemenu">
		     <li><a href="shop.html">Shop</a></li>
		     <li><a href="events.html">Events</a></li>
		     <li><a href="about.html">About Us</a></li>
			 <li><a href="apply.html">Work With Us</a></li>
		 </ul>
	 </div>
	 
	 <address class="blocks" id="contactus">
	     <h3>Contact us</h3>
		 <ul>
		     <li><em>pbparlorbooks@email.com</em></li>
			 <li><b>+351</b> <em>973-450-773</em></li>
			 <li><b>@pbparlorbooks</b><li>
		 </ul>
	 </address>
	 <p id="copyright">&#169; 2026 Paperback Parlor All Rights Reserved</p>
</section>
</footer>
 
</body>

</html>