<style>
     body {
	 background-color: White;
	 margin: 0;
	 padding: 0;
	 }
	 
     #header {
	     background-color: Teal;
		 height: 45px;
		 overflow: hidden;
	     #logo {
		     float: left;
			 width: 90px;
			 height: 35px;
			 margin-top: 5px;
			 margin-bottom: 5px;
			 margin-left: 45px;
		 }
		 
		 #menu {
		 padding-left: 490px;
		 position: absolute;
		 
	     a:hover {
	         color: #b78160;
	     }
	 
	     ul {
	         list-style-type: none;
		     overflow: hidden;
		 }
		 
	     ul li {
		     font-family: "Bebas Neue", sans-serif;
             font-weight: 400;
             font-style: normal;
			 display: inline;
	     }
		 
	     ul li a {
		     text-decoration: none;
		     text-align: center;
		     padding: 14px 16px;
		     color: white;
			 cursor: pointer;
	     }
		 }
 
		 #icons {
		     height: 45px;
		     margin-right: 45px;
		     margin-top: 0;
		     float: right;
			 display: flex;
             justify-content: center;
             align-items: center;

		 ul {
	         list-style-type: none;
		     overflow: hidden;
			 }
			 
		 ul li {
		 display: inline;
		 padding: 15px 15px;
		 }
			 
		 img {
		     width: 22px;
			 height: 22px;
		     }
		 
		 }
	 }
	 
	 #goback {
	 color: grey;
	 font-family: "Bebas Neue", sans-serif;
	     a {
		 text-decoration: none;
		 color: teal;
		 font-family: "Bebas Neue", sans-serif;
		 }
		 a:hover {
		 color: #b78160;
		 }
	 }
	 
	 #titledate {
	     width: 400px;
		 float: right;
	      h1 {
	         font-family: "Bebas Neue", sans-serif;
		     font-size: 40px;
		     color: #b78160;
			 width: 100px;
			 padding-left: 20px;
	         }
	 }
	 
	 #date {
	     font-family: "Bebas Neue", sans-serif;
		 font-size: 20px;
		 color: gray;
	     padding-left: 20px;
	 }
	 
	 #info {
	     font-family: "Bebas Neue", sans-serif;
		 font-size: 12px;
		 color: gray;
	     padding-left: 20px;
	 }
	 
	 
	 article {
	     width: 800px;
		 height: 700px;
		 margin: 0 auto;
		 padding-top: 40px;
		 overflow: hidden;
	 }
	 
	 #image {
	     float: left;
		 margin-top: 15px;
		     img {
			 width: 400px;
	         height: 250px;
			 }
	 }
	 
	 #body {
	 width: 800px;
	 height: 300px;
	 color: teal;
	 overflow: hidden;
	 padding-top: 20px;
	 padding-right: 40px;
	 text-align: justify;
     text-justify: inter-word;
	 }
	 
	 #base {
	     background-color: teal;
		 overflow: hidden;
		 height: 270px;
		 }
		 
	     #logobase {
		     float: left;
			 width: 150px;
			 margin-top: 55px;
			 margin-left: 150px;
		     img {
			     width: 200px;
			     height: 90px;
			 }
			 p {
			     color: white;
				 font-family: "Bebas Neue", sans-serif;
				 width: 170px;
				 font-size: 12px;
				 margin-left: 30px;
			 }
		 }
		 
		 #menubase {
			 margin-top: 55px;
			 margin-left: 260px;
			 align-items: center;
			     ul {
			     list-style-type: none;
				 } 
				 ul li {
				 padding: 5px;
				 display: block;
				 font-family: "Bebas Neue", sans-serif;
				 text-align: center;
				 }
				 a {
				 color: white;
				 text-decoration: none;
				 }
				 a:hover {
				 color: BurlyWood;
				 }
		 }
		 
		 #contactus {
		 float: right;
		 margin-right: 170px;
		 margin-top: 45px;
		     ul {
			     list-style-type: none;
			 } 
		     ul li {
				 padding: 5px;
				 font-family: "Bebas Neue", sans-serif;
				 display: block;
				 color: white;
			 }
		 h3 {
		 color: white;
		 font-family: "Bebas Neue", sans-serif;
		 padding-left: 43px;
		 }
		 }
		 
	 .blocks {
	     align-items: center;
	     display: inline-block; 
	 }
	 
	 #copyright {
	     color: white;
		 font-family: "Bebas Neue", sans-serif;
		 font-size: 11px;
		 margin-top: 50px;
